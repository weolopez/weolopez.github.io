#!/usr/bin/env bash
#
# claude-rc-ctl — manage scoped Claude Code Remote Control instances.
#
# Each instance is a systemd unit `claude-rc@<name>` that runs
#   claude --remote-control weolopez-<name>
# with WorkingDirectory=/root/weolopez.github.io/<name>, and is filesystem-fenced
# so it can only write inside that folder (the rest of the repo is read-only).
#
# The base server (claude-rc.service / "weolopez-server") is a separate unit and is
# never touched by this tool.
#
# Usage:
#   claude-rc-ctl ensure  <name>                idempotent "start the agent"; exits 4 if folder is missing
#   claude-rc-ctl create  <name> [--no-start]   create folder (if needed) + enable & start
#   claude-rc-ctl start    <name>
#   claude-rc-ctl stop     <name>
#   claude-rc-ctl restart  <name>
#   claude-rc-ctl delete   <name> [--purge]     stop + disable (keeps folder unless --purge)
#   claude-rc-ctl wire     <name>               mount <name>/api.ts into the Deno server (regen + restart, rollback on failure)
#   claude-rc-ctl unwire   <name>               remove <name>/api.ts from the Deno server
#   claude-rc-ctl list                          show all instances + the base server
#   claude-rc-ctl status   <name>
#   claude-rc-ctl logs     <name> [-f]
#
set -euo pipefail

ROOT=/root/weolopez.github.io
TEMPLATE=claude-rc@        # systemd template unit
BASE_UNIT=claude-rc.service
REGISTRY="$ROOT/.site-routes.json"          # wired sites (JSON array of names)
GENERATED="$ROOT/site-routes.generated.ts"  # auto-generated dispatcher imported by static-server.ts
HTTP_UNIT=http-server.service

err()  { printf '\033[31m%s\033[0m\n' "$*" >&2; }
ok()   { printf '\033[32m%s\033[0m\n' "$*"; }
info() { printf '%s\n' "$*"; }

validate_name() {
  local n="$1"
  if [[ ! "$n" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
    err "Invalid instance name '$n'. Use lowercase letters, digits, '-' or '_' (must start alphanumeric)."
    exit 2
  fi
  if [[ "$n" == "server" ]]; then
    err "'server' is reserved for the base weolopez-server instance."
    exit 2
  fi
}

unit_of() { echo "${TEMPLATE}${1}.service"; }
dir_of()  { echo "${ROOT}/${1}"; }

# Pre-accept Claude Code's "trust this folder?" dialog for a directory by seeding
# ~/.claude.json. Without this a headless instance hangs at the trust prompt and
# never registers its Remote Control session.
trust_dir() {
  local dir="$1"
  HOME=/root python3 - "$dir" <<'PY'
import json, os, sys, shutil
dir = sys.argv[1]
p = os.path.expanduser('~/.claude.json')
try:
    d = json.load(open(p))
except Exception:
    d = {}
projs = d.setdefault('projects', {})
e = projs.setdefault(dir, {})
before = (e.get('hasTrustDialogAccepted'), e.get('hasCompletedProjectOnboarding'), e.get('projectOnboardingSeenCount'))
e['hasTrustDialogAccepted'] = True
e['hasCompletedProjectOnboarding'] = True
e['projectOnboardingSeenCount'] = max(1, int(e.get('projectOnboardingSeenCount') or 0))
if before != (e.get('hasTrustDialogAccepted'), e.get('hasCompletedProjectOnboarding'), e.get('projectOnboardingSeenCount')):
    if os.path.exists(p): shutil.copy2(p, p + '.bak')
    tmp = p + '.tmp'
    json.dump(d, open(tmp, 'w'))
    os.replace(tmp, p)
    print('  trusted ' + dir)
else:
    print('  already trusted ' + dir)
PY
}

cmd_create() {
  local name="${1:?usage: create <name> [--no-start]}"; shift || true
  validate_name "$name"
  local start=1
  [[ "${1:-}" == "--no-start" ]] && start=0
  local dir; dir="$(dir_of "$name")"

  if [[ ! -d "$dir" ]]; then
    info "Creating folder $dir"
    mkdir -p "$dir"
  fi
  systemctl enable "$(unit_of "$name")" >/dev/null 2>&1 || true
  if [[ "$start" == 1 ]]; then
    trust_dir "$dir"
    systemctl start "$(unit_of "$name")"
    ok "Instance '$name' created and started (control name: weolopez-$name, scope: $dir)"
    systemctl --no-pager --lines=0 status "$(unit_of "$name")" | head -4 || true
  else
    ok "Instance '$name' created (enabled, not started). Run: claude-rc-ctl start $name"
  fi
}

# Idempotent "start the agent". Exits 4 (FOLDER_MISSING) if the folder doesn't exist
# so the caller can bootstrap the site (new-site skill) before starting.
cmd_ensure() {
  local name="${1:?usage: ensure <name>}"
  validate_name "$name"
  local dir; dir="$(dir_of "$name")"
  if [[ ! -d "$dir" ]]; then
    err "FOLDER_MISSING: $dir does not exist."
    err "Create the site first (new-site skill for ${name}.weolopez.com), then run: claude-rc-ctl create $name"
    exit 4
  fi
  local unit; unit="$(unit_of "$name")"
  if [[ "$(systemctl is-active "$unit" 2>/dev/null || true)" == "active" ]]; then
    ok "Agent '$name' is already running (weolopez-$name, scope: $dir)."
    return 0
  fi
  trust_dir "$dir"
  systemctl enable --now "$unit"
  ok "Agent '$name' started (weolopez-$name, scope: $dir)."
}

cmd_start()   { local n="${1:?usage: start <name>}";   validate_name "$n"; systemctl start   "$(unit_of "$n")"; ok "started $n"; }
cmd_stop()    { local n="${1:?usage: stop <name>}";    validate_name "$n"; systemctl stop    "$(unit_of "$n")"; ok "stopped $n"; }
cmd_restart() { local n="${1:?usage: restart <name>}"; validate_name "$n"; systemctl restart "$(unit_of "$n")"; ok "restarted $n"; }

cmd_delete() {
  local name="${1:?usage: delete <name> [--purge]}"; shift || true
  validate_name "$name"
  local purge=0
  [[ "${1:-}" == "--purge" ]] && purge=1
  systemctl disable --now "$(unit_of "$name")" >/dev/null 2>&1 || true
  ok "Instance '$name' stopped and disabled."
  local dir; dir="$(dir_of "$name")"
  if [[ "$purge" == 1 ]]; then
    err "NOT auto-deleting $dir (data safety). To remove its data run:  rm -rf '$dir'"
  else
    info "Folder preserved: $dir"
  fi
}

# Regenerate site-routes.generated.ts from the REGISTRY (JSON array of site names).
regen_generated() {
  HOME=/root python3 - "$REGISTRY" "$GENERATED" <<'PY'
import json, sys
reg_path, gen_path = sys.argv[1], sys.argv[2]
try:
    sites = sorted(set(json.load(open(reg_path))))
except Exception:
    sites = []
alias = lambda s: "s_" + s.replace("-", "_")
out = [
    "// AUTO-GENERATED by `claude-rc-ctl wire`. Do not edit by hand.",
    "// Mounts <site>/api.ts for sub-sites wired via the privileged `wire` step (Option B).",
    "// A site's api.ts must export a request handler (default, `handler`, or handle<Site>Api).",
    "",
]
for s in sites:
    out.append(f'import * as {alias(s)} from "./{s}/api.ts";')
out.append("")
out.append("const SITE_MODULES: Record<string, Record<string, unknown>> = {")
for s in sites:
    out.append(f'  "{s}": {alias(s)} as unknown as Record<string, unknown>,')
out.append("};")
out.append(r'''
function pickHandler(mod: Record<string, unknown>): ((req: Request) => Response | Promise<Response>) | null {
  const candidates: unknown[] = [
    mod.default,
    (mod as Record<string, unknown>).handler,
    ...Object.keys(mod).filter((k) => /^handle.*api$/i.test(k)).map((k) => mod[k]),
    ...Object.values(mod),
  ];
  for (const c of candidates) if (typeof c === "function") return c as (req: Request) => Response | Promise<Response>;
  return null;
}

export async function handleGeneratedSiteApi(request: Request): Promise<Response | null> {
  const m = new URL(request.url).pathname.match(/^\/([a-z0-9_-]+)\/api(?:\/|$)/);
  if (!m) return null;
  const mod = SITE_MODULES[m[1]];
  if (!mod) return null;
  const h = pickHandler(mod);
  return h ? await h(request) : null;
}
''')
open(gen_path, "w").write("\n".join(out) + "\n")
PY
}

# Restart the Deno server and confirm it's healthy (active + serves the homepage).
_http_healthy() {
  systemctl restart "$HTTP_UNIT"; sleep 2
  [[ "$(systemctl is-active "$HTTP_UNIT" 2>/dev/null || true)" == "active" ]] && curl -sf -o /dev/null http://localhost:8081/
}

cmd_wire() {
  local name="${1:?usage: wire <name>}"; validate_name "$name"
  local dir; dir="$(dir_of "$name")"
  [[ -d "$dir" ]]        || { err "No folder $dir — create the site first."; exit 2; }
  [[ -f "$dir/api.ts" ]] || { err "No $dir/api.ts. The site must export a request handler from api.ts (default, handler, or handle${name^}Api)."; exit 2; }

  cp "$GENERATED" "$GENERATED.bak" 2>/dev/null || true
  cp "$REGISTRY"  "$REGISTRY.bak"  2>/dev/null || echo "[]" > "$REGISTRY.bak"
  HOME=/root python3 -c 'import json,sys; p,n=sys.argv[1],sys.argv[2];
import os
d=json.load(open(p)) if os.path.exists(p) else []
json.dump(sorted(set(d+[n])), open(p,"w"))' "$REGISTRY" "$name"
  regen_generated
  info "Restarting $HTTP_UNIT to load $name/api.ts ..."
  if _http_healthy; then
    rm -f "$GENERATED.bak" "$REGISTRY.bak"
    ok "Wired '$name' → /$name/api/* is now served by $dir/api.ts."
  else
    err "Server failed health check after wiring '$name' — rolling back."
    mv -f "$GENERATED.bak" "$GENERATED"; mv -f "$REGISTRY.bak" "$REGISTRY"
    systemctl restart "$HTTP_UNIT"; sleep 2
    err "Rolled back. $dir/api.ts likely has an error (it runs in the main server on import). Server: $(systemctl is-active "$HTTP_UNIT")"
    exit 1
  fi
}

cmd_unwire() {
  local name="${1:?usage: unwire <name>}"; validate_name "$name"
  HOME=/root python3 -c 'import json,sys,os; p,n=sys.argv[1],sys.argv[2];
d=json.load(open(p)) if os.path.exists(p) else [];
json.dump([s for s in d if s!=n], open(p,"w"))' "$REGISTRY" "$name"
  regen_generated
  if _http_healthy; then ok "Unwired '$name' (its /$name/api/* routes are no longer mounted)."
  else err "Server unhealthy after unwiring '$name' — check $HTTP_UNIT."; exit 1; fi
}

cmd_list() {
  printf '%-18s %-10s %-9s %s\n' "INSTANCE" "STATE" "ENABLED" "SCOPE / CONTROL NAME"
  printf '%-18s %-10s %-9s %s\n' "------------------" "----------" "---------" "--------------------"
  # base server
  local bstate benabled
  bstate="$(systemctl is-active "$BASE_UNIT" 2>/dev/null || true)"
  benabled="$(systemctl is-enabled "$BASE_UNIT" 2>/dev/null || true)"
  printf '%-18s %-10s %-9s %s\n' "server (base)" "$bstate" "$benabled" "$ROOT  (weolopez-server)"
  # templated instances
  local found=0
  while read -r unit _; do
    [[ -z "$unit" ]] && continue
    local name="${unit#${TEMPLATE}}"; name="${name%.service}"
    local state enabled
    state="$(systemctl is-active "$unit" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
    printf '%-18s %-10s %-9s %s\n' "$name" "$state" "$enabled" "$(dir_of "$name")  (weolopez-$name)"
    found=1
  done < <(systemctl list-units --type=service --all --no-legend "${TEMPLATE}*.service" 2>/dev/null | awk '{print $1}')
  if [[ "$found" == 0 ]]; then
    info "(no scoped instances yet — create one with: claude-rc-ctl create <name>)"
  fi
}

cmd_status() { local n="${1:?usage: status <name>}"; validate_name "$n"; systemctl --no-pager status "$(unit_of "$n")"; }
cmd_logs()   {
  local n="${1:?usage: logs <name> [-f]}"; validate_name "$n"; shift || true
  if [[ "${1:-}" == "-f" ]]; then journalctl -u "$(unit_of "$n")" -n 60 -f
  else journalctl -u "$(unit_of "$n")" -n 60 --no-pager; fi
}

case "${1:-}" in
  ensure)  shift; cmd_ensure  "$@";;
  create)  shift; cmd_create  "$@";;
  start)   shift; cmd_start   "$@";;
  stop)    shift; cmd_stop    "$@";;
  restart) shift; cmd_restart "$@";;
  delete|rm) shift; cmd_delete "$@";;
  wire)    shift; cmd_wire   "$@";;
  unwire)  shift; cmd_unwire "$@";;
  list|ls) cmd_list;;
  status)  shift; cmd_status  "$@";;
  logs)    shift; cmd_logs    "$@";;
  ""|-h|--help|help)
    sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//';;
  *) err "Unknown command: $1"; err "Run 'claude-rc-ctl --help'"; exit 2;;
esac
